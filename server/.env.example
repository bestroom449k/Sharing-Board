# ===== 서버 =====
PORT=4000
NODE_ENV=development
# React(Vite) 개발 서버 주소. CORS 및 쿠키 허용 출처로 사용
CLIENT_ORIGIN=http://localhost:5173

# ===== MySQL 8 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sharing_app
DB_PASSWORD=여기에_DB_비밀번호
DB_NAME=sharing_board

# DB 초기화 스크립트(db:init)에서만 사용하는 관리자 계정.
# 데이터베이스/앱 계정을 생성하는 1회성 작업에만 쓰이며 평소 앱 구동에는 쓰지 않는다.
DB_ROOT_USER=root
DB_ROOT_PASSWORD=여기에_MySQL_root_비밀번호

# ===== 세션 =====
# 반드시 무작위 값으로 교체할 것(아래는 예시). node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex
SESSION_MAX_AGE_MS=604800000

# ===== EmailListVerify (이메일 유효성 서버사이드 검증) =====
# 키가 비어 있으면 형식(정규식) 검증만 수행한다.
EMAILLISTVERIFY_API_KEY=

# ===== 이미지 스토리지 (Cloudflare R2, S3 호환) =====
# 아래 5개가 모두 채워지면 R2 업로드, 비어 있으면 서버 로컬 디스크(uploads/)에 저장.
BACKEND_PUBLIC_URL=http://localhost:4000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 버킷 공개 주소(R2.dev 공개 URL 또는 커스텀 도메인). 예: https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
